# bot.py reads this file directly as a local fallback when macOS Keychain is not available.
# The keys intentionally match config.json token_keychain_account values and may contain hyphens.
# Do not run `source .env`; hyphenated keys are not shell variables.
# Prefer Keychain for production:
#   security add-generic-password -a "general-bot-token" -s "discord-bot" -w "YOUR_TOKEN" -U

general-bot-token=REPLACE_WITH_DISCORD_BOT_TOKEN
kb-bot-token=REPLACE_WITH_DISCORD_BOT_TOKEN
kanojo-bot-token=REPLACE_WITH_DISCORD_BOT_TOKEN
yumekano-coe-bot-token=REPLACE_WITH_DISCORD_BOT_TOKEN
